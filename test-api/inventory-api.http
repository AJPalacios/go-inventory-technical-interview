# Inventory API Test Suite
# Use with REST Client extension for VSCode
# https://marketplace.visualstudio.com/items\?itemName\=humao.rest-client

@baseUrl = http://localhost:8080
@apiVersion = /api/v1

# Variables for testing (based on actual seed data)
@productId = e08e3e7e-9126-49e4-9caf-63885a07bd78  # Teclado Mecánico Keychron K2 (Stock: 80 disponible, 15 reservado)
@requestId = {{$guid}}
@reservationId = b97bdd7a-29bb-498a-8dcc-a523ea4cedd0  # Existing reservation for testing releases

# Alternative product IDs from seed data:
# @productIdLaptop = 2d70d1dc-cd3a-4f40-afb0-52e16445bf36     # Laptop HP Pavilion 15 (25 available, 5 reserved)
# @productIdMouse = 2da3b8d3-69f1-46e6-a068-874532d5126a      # Mouse Logitech MX Master 3 (150 available, 10 reserved)
# @productIdMonitor = fc39adf6-784c-43f3-bb0d-9ed79613dd21    # Monitor Dell 27" 4K (30 available, 0 reserved)
# @productIdWebcam = cf43ddc3-c4da-4a98-b011-67b33223fae1     # Webcam Logitech C920 (45 available, 5 reserved)
# @productIdHeadphones = 47569eb2-fe19-43cb-929d-aedfd59dc199 # Audífonos Sony WH-1000XM4 (60 available, 10 reserved)
# @productIdSSD = f7d85ff3-6dbf-4ee8-bd61-54453610e441        # SSD Samsung 1TB (100 available, 0 reserved)
# @productIdRAM = 834004f0-f683-4e96-ae6b-bb6673869d24        # RAM Corsair 16GB DDR4 (200 available, 20 reserved)
# @productIdHub = cbb6a942-8687-4dd0-85ba-82f102f25ce1        # Hub USB-C Anker (75 available, 5 reserved)
# @productIdCable = 00907a59-5b4b-4432-8c49-e8bca4683799      # Cable HDMI 4K 2m (300 available, 0 reserved)

###############################################################################
# HEALTH & STATUS ENDPOINTS
###############################################################################

### 1. Basic Health Check
# Simple health check endpoint
GET {{baseUrl}}/health
Content-Type: application/json

###############################################################################
# INVENTORY STOCK OPERATIONS
###############################################################################

### 3. Get Stock Information
# Retrieve stock details for a specific product
GET {{baseUrl}}{{apiVersion}}/inventory/stock/{{productId}}
Content-Type: application/json
X-Request-ID: req-get-stock-{{$timestamp}}

###

### 4. Get Stock - Product Not Found (Test Error Handling)
# Test 404 error when product doesn't exist
GET {{baseUrl}}{{apiVersion}}/inventory/stock/non-existent-product
Content-Type: application/json
X-Request-ID: req-get-stock-404-{{$timestamp}}

###############################################################################
# RESERVE STOCK OPERATIONS
###############################################################################

### 5. Reserve Stock - Simple
# Basic stock reservation with minimal parameters
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: req-reserve-{{$guid}}

{
  "product_id": "{{productId}}",
  "quantity": 2,
  "request_id": "{{$guid}}",
  "timeout_seconds": 300,
  "reason": "Customer order",
  "metadata": {
    "order_id": "ORD-{{$timestamp}}",
    "customer_id": "CUST-12345"
  }
}

###

### 6. Reserve Stock - With Custom Timeout
# Reserve stock with 10 minute timeout
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: req-reserve-timeout-{{$guid}}

{
  "product_id": "{{productId}}",
  "quantity": 1,
  "request_id": "{{$guid}}",
  "timeout_seconds": 600,
  "reason": "Extended checkout session",
  "client_id": "web-app",
  "metadata": {
    "session_id": "sess-{{$timestamp}}",
    "checkout_step": "payment"
  }
}

###

### 7. Reserve Stock - Idempotency Test
# Test idempotency by using the same request_id twice
# First request
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: req-idempotency-test

{
  "product_id": "{{productId}}",
  "quantity": 1,
  "request_id": "idempotency-test-123",
  "timeout_seconds": 300,
  "reason": "Idempotency test"
}

###

### 8. Reserve Stock - Same Request ID (Should return cached result)
# Second request with same request_id - should return same result
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: req-idempotency-test-2

{
  "product_id": "{{productId}}",
  "quantity": 1,
  "request_id": "idempotency-test-123",
  "timeout_seconds": 300,
  "reason": "Idempotency test duplicate"
}

###

### 9. Reserve Stock - Insufficient Stock (Test Error)
# Try to reserve more stock than available
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: req-reserve-error-{{$guid}}

{
  "product_id": "{{productId}}",
  "quantity": 999999,
  "request_id": "{{$guid}}",
  "timeout_seconds": 300,
  "reason": "Test insufficient stock error"
}

###############################################################################
# BATCH RESERVE OPERATIONS
###############################################################################

### 10. Batch Reserve Stock
# Reserve stock for multiple products in one request
POST {{baseUrl}}{{apiVersion}}/inventory/batch/reserve
Content-Type: application/json
X-Request-ID: req-batch-{{$guid}}

{
  "requests": [
    {
      "product_id": "2da3b8d3-69f1-46e6-a068-874532d5126a",
      "quantity": 2,
      "request_id": "batch-{{$guid}}-1",
      "timeout_seconds": 300,
      "reason": "Mouse Logitech para oficina",
      "metadata": {
        "office_id": "OFF-001"
      }
    },
    {
      "product_id": "cf43ddc3-c4da-4a98-b011-67b33223fae1",
      "quantity": 1,
      "request_id": "batch-{{$guid}}-2",
      "timeout_seconds": 300,
      "reason": "Webcam para reuniones",
      "metadata": {
        "department": "IT"
      }
    },
    {
      "product_id": "00907a59-5b4b-4432-8c49-e8bca4683799",
      "quantity": 3,
      "request_id": "batch-{{$guid}}-3",
      "timeout_seconds": 300,
      "reason": "Cables HDMI para setup",
      "metadata": {
        "setup_id": "SETUP-{{$timestamp}}"
      }
    }
  ]
}

###############################################################################
# RELEASE STOCK OPERATIONS
###############################################################################

### 11. Release Stock Reservation
# Release a previously created reservation
# NOTE: Update reservation_id with actual ID from reserve response
POST {{baseUrl}}{{apiVersion}}/inventory/release
Content-Type: application/json
X-Request-ID: req-release-{{$guid}}

{
  "reservation_id": "REPLACE_WITH_ACTUAL_RESERVATION_ID",
  "reason": "cancelled",
  "request_id": "{{$guid}}"
}

###

### 12. Release Stock - Order Purchased
# Release reservation when order is completed
POST {{baseUrl}}{{apiVersion}}/inventory/release
Content-Type: application/json
X-Request-ID: req-release-purchased-{{$guid}}

{
  "reservation_id": "REPLACE_WITH_ACTUAL_RESERVATION_ID",
  "reason": "purchased",
  "request_id": "{{$guid}}"
}

###

### 13. Release Stock - Timeout
# Release reservation due to timeout
POST {{baseUrl}}{{apiVersion}}/inventory/release
Content-Type: application/json
X-Request-ID: req-release-timeout-{{$guid}}

{
  "reservation_id": "REPLACE_WITH_ACTUAL_RESERVATION_ID",
  "reason": "timeout",
  "request_id": "{{$guid}}"
}

###############################################################################
# UPDATE STOCK OPERATIONS
###############################################################################

### 14. Update Stock - Restock (Add inventory)
# Add new inventory to existing stock
PUT {{baseUrl}}{{apiVersion}}/inventory/stock
Content-Type: application/json
X-Request-ID: req-update-restock-{{$guid}}

{
  "product_id": "{{productId}}",
  "new_stock": 50,
  "adjustment_type": "restock",
  "reason": "New shipment received",
  "reference": "PO-{{$timestamp}}",
  "request_id": "{{$guid}}",
  "metadata": {
    "supplier": "ACME Corp",
    "warehouse": "WH-001"
  }
}

###

### 15. Update Stock - Adjustment
# Adjust stock for inventory correction
PUT {{baseUrl}}{{apiVersion}}/inventory/stock
Content-Type: application/json
X-Request-ID: req-update-adjustment-{{$guid}}

{
  "product_id": "{{productId}}",
  "new_stock": -5,
  "adjustment_type": "adjustment",
  "reason": "Inventory audit correction",
  "reference": "ADJ-{{$timestamp}}",
  "request_id": "{{$guid}}",
  "metadata": {
    "auditor": "John Doe",
    "audit_date": "2025-10-06"
  }
}

###

### 16. Update Stock - Return
# Add stock from customer return
PUT {{baseUrl}}{{apiVersion}}/inventory/stock
Content-Type: application/json
X-Request-ID: req-update-return-{{$guid}}

{
  "product_id": "{{productId}}",
  "new_stock": 3,
  "adjustment_type": "return",
  "reason": "Customer return processed",
  "reference": "RET-{{$timestamp}}",
  "request_id": "{{$guid}}",
  "metadata": {
    "return_reason": "Changed mind",
    "condition": "new"
  }
}

###

### 17. Update Stock - Correction
# Manual stock correction
PUT {{baseUrl}}{{apiVersion}}/inventory/stock
Content-Type: application/json
X-Request-ID: req-update-correction-{{$guid}}

{
  "product_id": "{{productId}}",
  "new_stock": 10,
  "adjustment_type": "correction",
  "reason": "Physical count mismatch",
  "reference": "CORR-{{$timestamp}}",
  "request_id": "{{$guid}}",
  "metadata": {
    "previous_count": 8,
    "actual_count": 10,
    "corrected_by": "Admin"
  }
}

###############################################################################
# ERROR HANDLING TESTS
###############################################################################

### 18. Invalid Product ID Format
GET {{baseUrl}}{{apiVersion}}/inventory/stock/invalid-format-!!!
Content-Type: application/json
X-Request-ID: req-error-format-{{$guid}}

###

### 19. Missing Required Fields
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: req-error-missing-{{$guid}}

{
  "product_id": "{{productId}}"
}

###

### 20. Invalid JSON
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: req-error-json-{{$guid}}

{
  "product_id": "{{productId}}",
  "quantity": "not-a-number"
}

###############################################################################
# WORKFLOW EXAMPLES
###############################################################################

### WORKFLOW 1: Complete Order Flow
# Step 1: Reserve Stock
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: workflow-1-reserve

{
  "product_id": "2d70d1dc-cd3a-4f40-afb0-52e16445bf36",
  "quantity": 2,
  "request_id": "workflow-order-{{$timestamp}}",
  "timeout_seconds": 600,
  "reason": "Customer checkout - Laptop HP",
  "client_id": "web-store",
  "metadata": {
    "order_id": "ORD-WORKFLOW-001",
    "customer_id": "CUST-999",
    "product_name": "Laptop HP Pavilion 15",
    "unit_price": "899.99",
    "currency": "USD"
  }
}

# Step 2: Get Stock (verify reservation)
# GET {{baseUrl}}{{apiVersion}}/inventory/stock/prod-001

# Step 3: Complete Order (release as purchased)
# POST {{baseUrl}}{{apiVersion}}/inventory/release
# {
#   "reservation_id": "USE_ID_FROM_STEP_1",
#   "reason": "purchased",
#   "request_id": "workflow-purchase-{{$timestamp}}"
# }

###

### WORKFLOW 2: Abandoned Cart Flow
# Step 1: Reserve Stock for Cart
POST {{baseUrl}}{{apiVersion}}/inventory/reserve
Content-Type: application/json
X-Request-ID: workflow-2-reserve

{
  "product_id": "47569eb2-fe19-43cb-929d-aedfd59dc199",
  "quantity": 1,
  "request_id": "workflow-cart-{{$timestamp}}",
  "timeout_seconds": 900,
  "reason": "Shopping cart - Audífonos Sony",
  "client_id": "mobile-app",
  "metadata": {
    "cart_id": "CART-WORKFLOW-002",
    "session_id": "SESSION-{{$timestamp}}",
    "product_name": "Audífonos Sony WH-1000XM4",
    "added_at": "{{$timestamp}}"
  }
}

# Step 2: Customer Abandons Cart (release)
# POST {{baseUrl}}{{apiVersion}}/inventory/release
# {
#   "reservation_id": "USE_ID_FROM_STEP_1",
#   "reason": "cancelled",
#   "request_id": "workflow-abandon-{{$timestamp}}"
# }

###

### WORKFLOW 3: Restock and Sell Flow
# Step 1: Add New Inventory
PUT {{baseUrl}}{{apiVersion}}/inventory/stock
Content-Type: application/json
X-Request-ID: workflow-3-restock

{
  "product_id": "f7d85ff3-6dbf-4ee8-bd61-54453610e441",
  "new_stock": 50,
  "adjustment_type": "restock",
  "reason": "Monthly SSD shipment from Samsung",
  "reference": "PO-WORKFLOW-003",
  "request_id": "workflow-restock-{{$timestamp}}",
  "metadata": {
    "supplier": "Samsung Electronics",
    "warehouse": "WH-CENTRAL",
    "shipment_date": "2025-10-06",
    "batch_number": "SSD-BATCH-{{$timestamp}}",
    "units_received": 50
  }
}

# Step 2: Check Updated Stock
# GET {{baseUrl}}{{apiVersion}}/inventory/stock/prod-003

# Step 3: Reserve Some Stock
# POST {{baseUrl}}{{apiVersion}}/inventory/reserve
# {
#   "product_id": "prod-003",
#   "quantity": 5,
#   "request_id": "workflow-sell-{{$timestamp}}",
#   "timeout_seconds": 300,
#   "reason": "New order"
# }

###############################################################################
# NOTES & REFERENCE DATA
###############################################################################

# VSCode REST Client Features:
# - Click "Send Request" above each ### separator
# - Use {{$guid}} for unique IDs
# - Use {{$timestamp}} for timestamps
# - Use {{$randomInt}} for random integers
# - Variables defined with @variable = value
# - Environment-specific variables supported

# SEED DATA REFERENCE (Current Stock Levels):
# ┌─────────────────────────────────────┬──────────────────────────────┬───────────┬──────────┐
# │ Product ID (UUID)                    │ Product Name                 │ Available │ Reserved │
# ├─────────────────────────────────────┼──────────────────────────────┼───────────┼──────────┤
# │ 2d70d1dc-cd3a-4f40-afb0-52e16445bf36 │ Laptop HP Pavilion 15        │    25     │    5     │
# │ 2da3b8d3-69f1-46e6-a068-874532d5126a │ Mouse Logitech MX Master 3   │   150     │   10     │
# │ e08e3e7e-9126-49e4-9caf-63885a07bd78 │ Teclado Mecánico Keychron K2 │    80     │   15     │ ⭐ Primary test product
# │ fc39adf6-784c-43f3-bb0d-9ed79613dd21 │ Monitor Dell 27" 4K          │    30     │    0     │
# │ cf43ddc3-c4da-4a98-b011-67b33223fae1 │ Webcam Logitech C920         │    45     │    5     │
# │ 47569eb2-fe19-43cb-929d-aedfd59dc199 │ Audífonos Sony WH-1000XM4    │    60     │   10     │
# │ f7d85ff3-6dbf-4ee8-bd61-54453610e441 │ SSD Samsung 1TB              │   100     │    0     │
# │ 834004f0-f683-4e96-ae6b-bb6673869d24 │ RAM Corsair 16GB DDR4        │   200     │   20     │
# │ cbb6a942-8687-4dd0-85ba-82f102f25ce1 │ Hub USB-C Anker              │    75     │    5     │
# │ 00907a59-5b4b-4432-8c49-e8bca4683799 │ Cable HDMI 4K 2m             │   300     │    0     │
# └─────────────────────────────────────┴──────────────────────────────┴───────────┴──────────┘

# EXISTING RESERVATIONS (for testing releases):
# ┌─────────────────────────────────────┬──────────┬──────────────────────────────┬────────┬───────────┐
# │ Reservation ID                       │ Req ID   │ Product                      │ Qty    │ Status    │
# ├─────────────────────────────────────┼──────────┼──────────────────────────────┼────────┼───────────┤
# │ 11171f8d-a6a4-42d3-9ab1-c6d3d829c83e │ req-001  │ Laptop HP                    │   2    │ confirmed │
# │ 1e30b07b-03cc-4b8d-9324-e69a316f0d5e │ req-002  │ Mouse Logitech               │   5    │ confirmed │
# │ b97bdd7a-29bb-498a-8dcc-a523ea4cedd0 │ req-003  │ Teclado Keychron             │   3    │ pending   │ ⭐ Use for release tests
# │ 846c4180-de70-410f-bc4b-4d287b123f2f │ req-004  │ Audífonos Sony               │  10    │ confirmed │
# │ ef9a3dc8-860f-4374-ab3c-4317f9f30d8c │ req-005  │ RAM Corsair                  │  15    │ pending   │
# └─────────────────────────────────────┴──────────┴──────────────────────────────┴────────┴───────────┘

# Available Reasons for Release:
# - cancelled: Customer cancelled order
# - purchased: Order completed successfully  
# - timeout: Reservation expired
# - expired: System expired reservation
# - admin: Manual admin release

# Available Adjustment Types for Stock Update:
# - restock: Adding new inventory
# - adjustment: Inventory correction  
# - return: Customer return
# - correction: Manual correction

# TESTING TIPS:
# 1. Use Teclado Keychron (e08e3e7e-...) as main test product (80 available)
# 2. Use existing reservation (b97bdd7a-...) for release testing
# 3. Products with 0 reserved stock are good for new reservations
# 4. Always check stock before/after operations with GET /stock/{id}
# 5. Use realistic quantities (1-10) to avoid hitting max limits
# 6. Include meaningful metadata for better debugging

###############################################################################
