# 🛒 Inventory API - Simple Test Suite
#
# 📋 SETUP:
# 1. Start server: make run
# 2. Server runs on: http://localhost:8080
# 3. Click "Send Request" above each ### separator
#
# � TEST PRODUCT
@baseUrl = http://localhost:8080
@productId = e08e3e7e-9126-49e4-9caf-63885a07bd78

###############################################################################
# 🏥 SYSTEM STATUS
###############################################################################

### Health Check
GET {{baseUrl}}/health

### API Documentation (open in browser)
GET {{baseUrl}}/docs

### OpenAPI Specification
GET {{baseUrl}}/openapi.json

###############################################################################
# 📦 BASIC OPERATIONS
###############################################################################

### Get Stock Information
GET {{baseUrl}}/api/v1/inventory/stock/{{productId}}

### Reserve Stock (Basic)
POST {{baseUrl}}/api/v1/inventory/reserve
Content-Type: application/json

{
  "product_id": "{{productId}}",
  "quantity": 2,
  "request_id": "{{$guid}}",
  "timeout_seconds": 300,
  "reason": "Customer order"
}

### Release Stock 
# Replace RESERVATION_ID with actual ID from reserve response
POST {{baseUrl}}/api/v1/inventory/release
Content-Type: application/json

{
  "reservation_id": "REPLACE_WITH_ACTUAL_RESERVATION_ID",
  "reason": "cancelled",
  "request_id": "{{$guid}}"
}

### Update Stock (Add Inventory)
PUT {{baseUrl}}/api/v1/inventory/stock
Content-Type: application/json

{
  "product_id": "{{productId}}",
  "new_stock": 50,
  "adjustment_type": "restock",
  "reason": "New shipment received",
  "reference": "PO-{{$timestamp}}",
  "request_id": "{{$guid}}"
}

###############################################################################
# 🔧 ADVANCED OPERATIONS
###############################################################################

### Batch Reserve (Multiple Products)
POST {{baseUrl}}/api/v1/inventory/batch/reserve
Content-Type: application/json

{
  "requests": [
    {
      "product_id": "2da3b8d3-69f1-46e6-a068-874532d5126a",
      "quantity": 2,
      "request_id": "batch-{{$guid}}-1",
      "timeout_seconds": 300,
      "reason": "Bulk order item 1"
    },
    {
      "product_id": "cf43ddc3-c4da-4a98-b011-67b33223fae1",
      "quantity": 1,
      "request_id": "batch-{{$guid}}-2",
      "timeout_seconds": 300,
      "reason": "Bulk order item 2"
    }
  ]
}

###############################################################################
# ❌ ERROR TESTING
###############################################################################

### Invalid Product ID
GET {{baseUrl}}/api/v1/inventory/stock/invalid-uuid-format
