###############################################################################
# RELEASE STOCK ERRORS
###############################################################################

### Missing reservation_id
POST {{baseUrl}}/api/v1/inventory/release
Content-Type: application/json

{
  "reason": "Cancel reservation"
}

### Invalid reservation_id format
POST {{baseUrl}}/api/v1/inventory/release
Content-Type: application/json

{
  "reservation_id": "not-a-valid-uuid",
  "reason": "Cancel reservation"
}

###############################################################################
# GET STOCK ERRORS
###############################################################################

### Invalid product ID in URL
GET {{baseUrl}}/api/v1/inventory/stock/not-a-uuid

### Non-existent product
GET {{baseUrl}}/api/v1/inventory/stock/00000000-0000-0000-0000-000000000000

